[
  {
    "label": "zig build debug",
    "command": "zig",
    "args": ["build", "-Doptimize=Debug"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "save": "all",
    "reveal": "always",
    "hide": "on_success"
  },
  {
    "label": "zig build release",
    "command": "zig",
    "args": ["build", "-Doptimize=ReleaseSafe"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "save": "all",
    "reveal": "always",
    "hide": "on_success"
  },
  {
    "label": "zig run",
    "command": "zig",
    "args": ["build", "run", "-Doptimize=Debug"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "save": "all",
    "reveal": "always",
    "hide": "never",
    "use_new_terminal": false,
    "allow_concurrent_runs": true
  },
  {
    "label": "zig test",
    "command": "zig",
    "args": ["build", "test", "-Doptimize=Debug"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "save": "all",
    "reveal": "always",
    "hide": "never"
  },
  {
    "label": "zig fmt current file",
    "command": "zig",
    "args": ["fmt", "$ZED_FILE"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "save": "current",
    "reveal": "always",
    "hide": "on_success"
  }
]
